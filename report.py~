from reportlab.platypus import SimpleDocTemplate, Paragraph, Spacer, Table, TableStyle
from reportlab.platypus import Frame, PageTemplate
from reportlab.lib.styles import getSampleStyleSheet, ParagraphStyle
from reportlab.lib.enums import TA_LEFT, TA_RIGHT
from reportlab.lib.pagesizes import A4
from reportlab.lib import colors

# Create document
doc = SimpleDocTemplate(
    "ozone_offer_cover.pdf",
    pagesize=A4,
    rightMargin=60,
    leftMargin=60,
    topMargin=80,
    bottomMargin=60
)

styles = getSampleStyleSheet()

# --- Custom Styles ---
title_style = ParagraphStyle(
    'TitleStyle',
    parent=styles['Normal'],
    fontName='Helvetica-Bold',
    fontSize=22,
    leading=28,
    spaceAfter=20
)

subtitle_style = ParagraphStyle(
    'SubtitleStyle',
    parent=styles['Normal'],
    fontName='Helvetica',
    fontSize=12,
    leading=16,
    textColor=colors.grey
)

client_style = ParagraphStyle(
    'ClientStyle',
    parent=styles['Normal'],
    fontName='Helvetica-Bold',
    fontSize=14,
    spaceBefore=40,
    spaceAfter=10
)

meta_style = ParagraphStyle(
    'MetaStyle',
    parent=styles['Normal'],
    fontName='Helvetica',
    fontSize=10,
    textColor=colors.grey
)

footer_style = ParagraphStyle(
    'FooterStyle',
    parent=styles['Normal'],
    fontName='Helvetica',
    fontSize=9,
    textColor=colors.grey,
    alignment=TA_RIGHT
)

# --- Content ---
elements = []

# Company Name (top-left, strong identity)
elements.append(Paragraph("YOUR COMPANY NAME S.R.L.", title_style))
elements.append(Paragraph("Industrial Ozone Engineering & Consulting", subtitle_style))

elements.append(Spacer(1, 80))

# Main Title
elements.append(Paragraph(
    "TECHNICAL AND COMMERCIAL PROPOSAL",
    title_style
))

elements.append(Paragraph(
    "Design, Supply and Integration of Industrial Ozone Systems",
    subtitle_style
))

elements.append(Spacer(1, 60))

# Client Section
elements.append(Paragraph("Prepared for:", client_style))
elements.append(Paragraph("CLIENT COMPANY NAME", title_style))

elements.append(Spacer(1, 40))

# Metadata Table (very corporate/legal feel)
data = [
    ["Project Reference:", "OZ-2026-001"],
    ["Date:", "March 2026"],
    ["Prepared by:", "Your Company Name S.R.L."],
    ["Confidentiality:", "Strictly Private & Confidential"]
]

table = Table(data, colWidths=[150, 300])
table.setStyle(TableStyle([
    ('FONTNAME', (0, 0), (-1, -1), 'Helvetica'),
    ('FONTSIZE', (0, 0), (-1, -1), 10),
    ('TEXTCOLOR', (0, 0), (-1, -1), colors.black),
    ('BOTTOMPADDING', (0, 0), (-1, -1), 8),
    ('LINEBELOW', (0, 0), (-1, -1), 0.25, colors.grey),
]))

elements.append(table)

elements.append(Spacer(1, 120))

# Footer (law firm style)
elements.append(Paragraph(
    "Confidential – This document contains proprietary engineering and commercial information.",
    footer_style
))

# Build document
doc.build(elements)